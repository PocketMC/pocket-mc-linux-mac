<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PocketMC.App.ViewModels"
        x:Class="PocketMC.App.Views.StartupUpdateWindow"
        x:DataType="vm:StartupUpdateViewModel"
        Title="Software Update Available"
        Width="550" Height="450"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="A new version of PocketMC is available!" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding Version, StringFormat='Version {0} is now available for download.'}" Foreground="{DynamicResource TextMutedBrush}"/>
        </StackPanel>

        <!-- Release Notes -->
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" Padding="16">
            <ScrollViewer>
                <TextBlock Text="{Binding ReleaseNotes}" TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Footer / Controls -->
        <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center" IsVisible="{Binding IsDownloading}">
                <TextBlock Text="Downloading update..." Margin="0,0,0,4"/>
                <ProgressBar Value="{Binding DownloadProgress}" Minimum="0" Maximum="100"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" IsEnabled="{Binding !IsDownloading}">
                <Button Content="Skip This Version" Command="{Binding SkipCommand}"/>
                <Button Content="Remind Me Later" Command="{Binding RemindLaterCommand}"/>
                <Button Content="Install Update" Command="{Binding UpdateCommand}" Classes="accent"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
