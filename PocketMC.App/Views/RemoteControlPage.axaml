<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PocketMC.App.ViewModels"
             xmlns:lucide="using:Lucide.Avalonia"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="650"
             x:Class="PocketMC.App.Views.RemoteControlPage"
             x:DataType="vm:RemoteControlViewModel">

    <Grid RowDefinitions="Auto, *">
        <!-- HEADER BAR -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" Padding="16,12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding NavigateBackCommand}" 
                        Background="Transparent" BorderThickness="0" Padding="8" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <lucide:LucideIcon Kind="ArrowLeft" Size="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Back to Dashboard" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="Remote Control Dashboard" 
                           FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid ColumnDefinitions="1.2*, *" Margin="20">
                
                <!-- LEFT COLUMN: SETTINGS CARDS -->
                <StackPanel Grid.Column="0" Spacing="20" Margin="0,0,12,0">
                    
                    <!-- SERVER CONNECTION CARD -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                                <lucide:LucideIcon Kind="Radio" Size="20" Foreground="#1e90ff" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Server Connection" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Enable remote dashboard hosting and configure the port" FontSize="11" Opacity="0.6" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            
                            <Separator Background="{DynamicResource CardBorderBrush}" Height="1" Margin="0,2"/>

                            <ToggleSwitch IsChecked="{Binding IsEnabled}" Content="Enable Remote Dashboard" OffContent="Disabled" OnContent="Active" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <StackPanel Spacing="6" IsEnabled="{Binding IsEnabled}">
                                <TextBlock Text="Port Configuration" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <NumericUpDown Value="{Binding Port}" Minimum="1" Maximum="65535" FormatString="F0" HorizontalAlignment="Stretch" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ACCESS SECURITY CARD -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                                <lucide:LucideIcon Kind="Key" Size="20" Foreground="#2ecc71" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Access Security" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Secure remote access to prevent unauthorized controls" FontSize="11" Opacity="0.6" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="{DynamicResource CardBorderBrush}" Height="1" Margin="0,2"/>

                            <ToggleSwitch IsChecked="{Binding RequireAuthentication}" Content="Require Password Authentication" OffContent="Disabled" OnContent="Enabled" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            
                            <StackPanel Spacing="6" IsEnabled="{Binding RequireAuthentication}">
                                <TextBlock Text="Set Session Password" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBox Text="{Binding Password}" PasswordChar="*" Watermark="Leave blank to keep existing password" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PERMISSION SETTINGS CARD -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,4">
                                <lucide:LucideIcon Kind="Shield" Size="20" Foreground="#e67e22" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Permissions" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Control what actions remote paired devices can perform" FontSize="11" Opacity="0.6" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Background="{DynamicResource CardBorderBrush}" Height="1" Margin="0,2"/>

                            <StackPanel Spacing="12">
                                <CheckBox IsChecked="{Binding AllowRemoteConsoleCommands}" Content="Allow Remote Console Commands" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <CheckBox IsChecked="{Binding AllowRemotePlayerActions}" Content="Allow Remote Player Actions (Start / Stop)" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SAVE BUTTON -->
                    <Button Command="{Binding SaveSettingsCommand}" Background="#1e90ff" Foreground="White" CornerRadius="8" Padding="20,12" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <lucide:LucideIcon Kind="Save" Size="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Save Settings" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- RIGHT COLUMN: PAIRING & ACCESS DETAILS -->
                <StackPanel Grid.Column="1" Spacing="20" Margin="12,0,0,0">
                    
                    <!-- PAIRING CARD -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" IsVisible="{Binding IsEnabled}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,0,0,4">
                                <lucide:LucideIcon Kind="Smartphone" Size="20" Foreground="#9b59b6" VerticalAlignment="Center"/>
                                <TextBlock Text="Pair Device" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="Scan this QR code with your mobile device camera to open the dashboard automatically." 
                                       TextWrapping="Wrap" FontSize="12" Opacity="0.7" Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center"/>
                            
                            <!-- QR Code card border -->
                            <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Background="White" Margin="0,8">
                                <Image Source="{Binding PairingQrCode}" Width="220" Height="220" />
                            </Border>

                            <Separator Background="{DynamicResource CardBorderBrush}" Height="1" Margin="0,2"/>

                            <!-- Manual access -->
                            <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                                <TextBlock Text="Manual Connection Link" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBox Grid.Column="0" Text="{Binding PairingUrl}" IsReadOnly="True" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <Button Grid.Column="1" Command="{Binding CopyUrlCommand}" ToolTip.Tip="Copy Link" Background="Transparent" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Padding="8" CornerRadius="6" VerticalAlignment="Center">
                                        <lucide:LucideIcon Kind="Copy" Size="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- PAIRING STATE PLACEHOLDER (when disabled) -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="30" IsVisible="{Binding !IsEnabled}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <lucide:LucideIcon Kind="ServerCrash" Size="48" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.3" HorizontalAlignment="Center"/>
                            <TextBlock Text="Dashboard Offline" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Enable the remote control dashboard from settings to generate pairing codes." 
                                       TextWrapping="Wrap" FontSize="12" Opacity="0.5" Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
