<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PocketMC.App.ViewModels"
             xmlns:lucide="clr-namespace:Lucide.Avalonia;assembly=Lucide.Avalonia"
             x:Class="PocketMC.App.Views.ServerConsolePage"
             x:DataType="vm:ServerConsoleViewModel"
             x:CompileBindings="True"
             Margin="24">

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Top Action & Filter Bar -->
        <Grid Grid.Row="0" Margin="0,0,0,16" ColumnDefinitions="*, Auto">
            <!-- Left Info Section -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Command="{Binding GoBackCommand}"
                        Background="Transparent" BorderThickness="0" Padding="8" Cursor="Hand" ToolTip.Tip="Go Back">
                    <lucide:LucideIcon Kind="ArrowLeft" Size="20" StrokeWidth="2"/>
                </Button>
                <TextBlock Text="{Binding SelectedInstance.Name, StringFormat='{}Console - {0}'}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>

            <!-- Right Filters -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBox Width="220" Height="34" Text="{Binding SearchQuery, Mode=TwoWay}" Watermark="Search logs..." VerticalAlignment="Center" VerticalContentAlignment="Center"/>
                <CheckBox IsChecked="{Binding AutoScroll, Mode=TwoWay}" VerticalAlignment="Center">
                    <TextBlock Text="Auto Scroll" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </CheckBox>
            </StackPanel>
        </Grid>

        <!-- Main Console Terminal Area -->
        <Border Grid.Row="1" 
                Background="{DynamicResource ConsoleBackgroundBrush}" 
                CornerRadius="8" 
                BorderBrush="{DynamicResource CardBorderBrush}" 
                BorderThickness="1" 
                Padding="16"
                BoxShadow="0 8 24 0 #15000000">
            <Grid RowDefinitions="Auto, Auto, *">
                <!-- Terminal Header -->
                <Border Grid.Row="0" 
                        Background="{DynamicResource ConsoleHeaderBackgroundBrush}" 
                        CornerRadius="6" 
                        Padding="12,8" 
                        Margin="0,0,0,12"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1">
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="#4CAF50" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SelectedInstance.Name, StringFormat='{}Active Terminal: {0}'}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="{Binding LogEntryCount, StringFormat='{}{0} entries'}" Grid.Column="1" Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.6" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Button Grid.Column="2" Command="{Binding CopyLogsCommand}" Background="Transparent" BorderThickness="0" Padding="6" ToolTip.Tip="Copy Terminal Logs to Clipboard" Cursor="Hand">
                            <lucide:LucideIcon Kind="Copy" Size="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Crash Diagnostics Warning Banner -->
                <Border Grid.Row="1" 
                        Background="#2a1616" 
                        BorderBrush="#501616" 
                        BorderThickness="1" 
                        CornerRadius="6" 
                        Padding="12,8" 
                        Margin="0,0,0,12" 
                        IsVisible="{Binding IsCrashed}">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <lucide:LucideIcon Kind="ShieldAlert" Size="16" Foreground="#e74c3c" VerticalAlignment="Center"/>
                            <TextBlock Text="Server crashed or stopped unexpectedly! Run diagnostics helper to troubleshoot." 
                                       Foreground="#f5b0a7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding NavigateToAiDiagnosticCommand}" 
                                Background="#1e90ff" Foreground="White" CornerRadius="4" Padding="10,4" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <lucide:LucideIcon Kind="Sparkles" Size="12" VerticalAlignment="Center"/>
                                <TextBlock Text="Analyze with AI" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Scrollable Log Container -->
                <ScrollViewer Grid.Row="2" Name="LogScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:LogLine">
                                <SelectableTextBlock Text="{Binding Text}"
                                                     Foreground="{Binding ColorBrush}"
                                                     FontFamily="Cascadia Code, JetBrains Mono, Fira Code, Consolas, Menlo, Monospace"
                                                     FontSize="13"
                                                     LineHeight="20"
                                                     TextWrapping="Wrap"
                                                     Margin="0,0,0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Command Input Box -->
        <Grid Grid.Row="2" Margin="0,16,0,0" ColumnDefinitions="*, Auto">
            <TextBox Grid.Column="0" 
                     Text="{Binding CommandInput, Mode=TwoWay}" 
                     KeyDown="OnCommandBoxKeyDown" 
                     Watermark="Type server command (e.g., say Hello, op Player, stop)..." 
                     FontFamily="Cascadia Code, JetBrains Mono, Fira Code, Consolas, Menlo, Monospace" 
                     FontSize="13" 
                     Padding="12,10"
                     VerticalContentAlignment="Center"
                     Height="40"/>
            <Button Grid.Column="1" Command="{Binding SendCommandCommand}" Cursor="Hand" Margin="12,0,0,0" Padding="20,0" Height="40" Background="#1E90FF" Foreground="White" CornerRadius="6">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <lucide:LucideIcon Kind="Send" Size="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Send" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
