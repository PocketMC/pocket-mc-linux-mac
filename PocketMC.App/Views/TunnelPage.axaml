<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PocketMC.App.ViewModels"
             xmlns:lucide="using:Lucide.Avalonia"
             xmlns:tunnels="using:PocketMC.RemoteControl.Tunnels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PocketMC.App.Views.TunnelPage"
             x:DataType="vm:TunnelViewModel">

    <Grid RowDefinitions="Auto, *">
        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="16">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Padding="8" CornerRadius="8" Margin="0,0,12,0">
                    <lucide:LucideIcon Kind="ArrowLeft" Size="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Internet Tunnels" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Expose server ports to the internet securely via Playit.gg" FontSize="12" Opacity="0.7" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
                <Button Grid.Column="2" Command="{Binding RefreshAllCommand}" Background="Transparent" Padding="8" CornerRadius="8">
                    <lucide:LucideIcon Kind="RefreshCw" Size="18" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" Padding="24">
            <StackPanel Spacing="16">
                <!-- ERROR MESSAGE -->
                <Border Background="#2a1818" BorderBrush="#ef4444" BorderThickness="1" CornerRadius="8" Padding="16" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <Grid ColumnDefinitions="Auto, *">
                        <lucide:LucideIcon Grid.Column="0" Kind="ShieldAlert" Size="20" Foreground="#ef4444" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding ErrorMessage}" Foreground="#fecaca" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*, 20, 1.5*">
                    <!-- LEFT COLUMN: AGENT & CREATE TUNNEL -->
                    <StackPanel Grid.Column="0" Spacing="16">
                        <!-- AGENT STATUS CARD -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <lucide:LucideIcon Kind="Activity" Size="20" Foreground="#1E90FF"/>
                                    <TextBlock Text="Playit Agent Status" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" Margin="4,0,0,0">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Status:" FontWeight="Medium" Opacity="0.7" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AgentStatus}" FontWeight="Bold" Foreground="{Binding IsAgentRunning, Converter={x:Static ObjectConverters.IsNull}, ConverterParameter='#2ecc71'}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Agent ID:" FontWeight="Medium" Opacity="0.7" Margin="0,4,8,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AgentId}" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button Command="{Binding StartAgentCommand}" IsEnabled="{Binding !IsAgentRunning}" Background="#2ecc71" Foreground="White" CornerRadius="8" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <lucide:LucideIcon Kind="Play" Size="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Start" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding StopAgentCommand}" IsEnabled="{Binding IsAgentRunning}" Background="#e74c3c" Foreground="White" CornerRadius="8" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <lucide:LucideIcon Kind="Square" Size="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Stop" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding OpenSetupWizardCommand}" IsVisible="{Binding !IsLinked}" Background="Transparent" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Foreground="{DynamicResource TextPrimaryBrush}" CornerRadius="8" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <lucide:LucideIcon Kind="Link" Size="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Link Account" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding UnlinkAccountCommand}" IsVisible="{Binding IsLinked}" Background="Transparent" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Foreground="#e74c3c" CornerRadius="8" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <lucide:LucideIcon Kind="Unlink" Size="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Unlink Account" FontWeight="Medium" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CREATE TUNNEL CARD -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" IsVisible="{Binding IsLinked}">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <lucide:LucideIcon Kind="Plus" Size="20" Foreground="#1E90FF"/>
                                    <TextBlock Text="Create New Tunnel" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>

                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Tunnel Name" FontSize="12" Opacity="0.7"/>
                                        <TextBox Text="{Binding NewTunnelName}" Watermark="e.g. My Java Server" CornerRadius="8"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Local Port" FontSize="12" Opacity="0.7"/>
                                        <TextBox Text="{Binding NewTunnelPort}" Watermark="e.g. 25565" CornerRadius="8"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Tunnel Type" FontSize="12" Opacity="0.7"/>
                                        <ComboBox SelectedItem="{Binding NewTunnelType}" ItemsSource="{Binding TunnelTypes}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>

                                    <Button Command="{Binding CreateTunnelCommand}" IsEnabled="{Binding !IsCreatingTunnel}" Background="#1E90FF" Foreground="White" CornerRadius="8" HorizontalAlignment="Stretch" Padding="12" Margin="0,8,0,0">
                                        <TextBlock Text="Create Tunnel" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- RIGHT COLUMN: ACTIVE TUNNELS LIST -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <lucide:LucideIcon Kind="Globe" Size="20" Foreground="#1E90FF"/>
                                    <TextBlock Text="Active Tunnels" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <!-- EMPTY STATE -->
                            <StackPanel Spacing="12" Margin="0,24" HorizontalAlignment="Center" IsVisible="{Binding !Tunnels.Count}">
                                <lucide:LucideIcon Kind="Network" Size="48" Opacity="0.3" HorizontalAlignment="Center"/>
                                <TextBlock Text="No active tunnels found" FontSize="14" Opacity="0.7" HorizontalAlignment="Center"/>
                                <TextBlock Text="Create a tunnel or link your agent to expose your servers." FontSize="12" Opacity="0.5" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                            </StackPanel>

                            <!-- LIST -->
                            <ItemsControl ItemsSource="{Binding Tunnels}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="tunnels:TunnelData">
                                        <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <Border Background="{DynamicResource CardBorderBrush}" CornerRadius="4" Padding="6,2">
                                                            <TextBlock Text="{Binding TunnelTypeDisplay}" FontSize="10" FontWeight="SemiBold" Opacity="0.8"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="Local Port:" FontSize="12" Opacity="0.7"/>
                                                        <TextBlock Text="{Binding Port}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasPublicAddress}">
                                                        <TextBlock Text="Public IP:" FontSize="12" Opacity="0.7"/>
                                                        <SelectableTextBlock Text="{Binding PublicAddress}" FontSize="12" FontWeight="Bold" Foreground="#1E90FF"/>
                                                    </StackPanel>
                                                    
                                                    <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding !HasPublicAddress}">
                                                        <TextBlock Text="Waiting for allocation..." FontSize="12" Opacity="0.5" FontStyle="Italic"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <ToggleSwitch IsChecked="{Binding IsEnabled}" Command="{Binding $parent[UserControl].((vm:TunnelViewModel)DataContext).ToggleTunnelCommand}" CommandParameter="{Binding}" OnContent="" OffContent="" VerticalAlignment="Center"/>
                                                    <Button Command="{Binding $parent[UserControl].((vm:TunnelViewModel)DataContext).DeleteTunnelCommand}" CommandParameter="{Binding Id}" Background="Transparent" Foreground="#e74c3c" Padding="8" CornerRadius="8" VerticalAlignment="Center">
                                                        <lucide:LucideIcon Kind="Trash2" Size="16"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
